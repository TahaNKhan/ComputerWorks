{
  "name": "computerworks",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --env-file=.env run --filter @computerworks/server start:dev",
    "build": "tsc -b tsconfig.build.json",
    "build:clean": "rm -rf packages/*/dist && bun run build",
    "test": "bun test",
    "test:e2e": "bun run scripts/e2e.ts",
    "typecheck": "tsc -b tsconfig.build.json",
    "lint": "echo 'lint not configured yet'",
    "start": "bun --env-file=.env run --filter @computerworks/server start"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "typescript": "^5.6.3",
    "vite": "^5"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@types/node": "^26.0.1",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^9",
    "rehype-sanitize": "^6",
    "remark-gfm": "^4",
    "shiki": "^1",
    "zustand": "^4"
  }
}
