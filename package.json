{
  "name": "computerworks",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '@computerworks/server' start:dev",
    "build": "bun run --filter '@computerworks/*' build",
    "test": "bun test",
    "typecheck": "bun run --filter '@computerworks/*' typecheck",
    "lint": "echo 'lint not configured yet'",
    "start": "bun run --filter @computerworks/server start"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
