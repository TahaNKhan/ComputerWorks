# ComputerWorks env file template.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Bun auto-loads it via `--env-file=.env` in the root + server `start` /
# `start:dev` scripts. See README "Configure" section.
#
# Required for talking to the MiniMax Anthropic-compatible endpoint.

MINIMAX_TOKEN=your-token-here
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_DEFAULT_MODEL=MiniMax-M3
