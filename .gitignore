# Dependencies
node_modules/
.pnp.*

# Bun
bun.lockb

# Build output
dist/
dist-app/
build/
*.tsbuildinfo

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*~

# ─── Env / secrets ─────────────────────────────────────────────────────────
# NEVER commit credentials. The Anthropic provider in this repo reads
# MINIMAX_TOKEN and MINIMAX_BASE_URL from the environment (sourced from
# ~/.bashrc or your shell rc) — never from a tracked file.
.env
.env.*
!.env.example
.envrc
.envrc.*
.direnv/
*.pem
*.key
*.p12
*.pfx

# Common accidental-secret surfaces
.claude/
.cursor/
.aider*
.continue/
*.log.local
npm-debug.log*
bun-debug.log*
yarn-debug.log*
yarn-error.log*

# Hermes state (between cron runs)
.hermes-state.json

# Backup / scratch files some editors drop alongside real ones
*.bak
*.orig
*.rej

# ── TypeScript composite build artifacts ───────────────────────────────────
# When a package has "composite": true (required for `tsc -b` project
# references), TypeScript emits declaration files (*.d.ts) next to
# the source — by design, for incremental builds. Source maps go to
# the outDir. We gitignore them all here so no per-package .gitignore
# is needed.
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map
packages/*/src/**/*.js
packages/*/src/**/*.js.map
