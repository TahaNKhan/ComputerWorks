{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "composite": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable",
      "WebWorker"
    ],
    "types": [
      "vite/client"
    ],
    "paths": {
      "@computerworks/core": ["../core/src/index.ts"],
      "@computerworks/core/*": ["../core/src/*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "dist",
    "dist-app",
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "vite.config.ts"
  ]
}
